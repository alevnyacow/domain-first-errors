{
    "name": "@domain-first/errors",
    "description": "Strongly typed domain errors that remain identifiable across application boundaries",
    "version": "1.5.2",
    "repository": {
        "type": "git",
        "url": "https://github.com/alevnyacow/domain-first-errors.git"
    },
    "license": "MIT",
    "keywords": [
        "errors",
        "domain errors",
        "error",
        "domain error",
        "exceptions",
        "domain-first",
        "ddd",
        "domain-driven"
    ],
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "rslib",
        "check": "biome check --write",
        "dev": "rslib --watch",
        "format": "biome format --write",
        "test": "rstest",
        "test:watch": "rstest --watch"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.15",
        "@rslib/core": "^0.23.2",
        "@rstest/adapter-rslib": "^0.10.6",
        "@rstest/core": "^0.10.6",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/npm": "^13.1.5",
        "@types/node": "^24.13.2",
        "semantic-release": "^25.0.8",
        "typescript": "^6.0.3"
    }
}
